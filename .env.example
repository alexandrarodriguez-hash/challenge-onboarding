# ─── Amplitude Analytics ───────────────────────────────────────────────────
# Client key del proyecto de Amplitude. Amplitude → Settings → Projects → API Key
VITE_AMPLITUDE_API_KEY=

# ─── Amplitude Experiment ──────────────────────────────────────────────────
# Client key del deployment "amplistore-experiment".
# Amplitude → Experiment → Deployments → amplistore-experiment → Client key
VITE_AMPLITUDE_EXPERIMENT_KEY=

# ─── Braze Web SDK ──────────────────────────────────────────────────────────
# API Key del tipo Web (JS SDK), creada en Braze Dashboard > Developer Console > API Keys.
# No confundir con la REST API Key que usa el backend.
VITE_BRAZE_API_KEY=

# Endpoint del SDK según el cluster de tu instancia Braze (sin "rest.").
# Braze Dashboard > Developer Console > SDK Endpoint
# Ejemplo: sdk.iad-01.braze.com
VITE_BRAZE_SDK_ENDPOINT=

# ─── Backend ────────────────────────────────────────────────────────────────
# URL base del backend Spring Boot (minders-braze-backend).
VITE_API_BASE=http://localhost:8080
